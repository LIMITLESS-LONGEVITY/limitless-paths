{
  "name": "limitless-paths",
  "version": "1.0.0",
  "description": "PATHS educational platform by LIMITLESS — Payload CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "guide:search-index": "tsx scripts/build-guide-search-index.ts",
    "guide:capture": "tsx scripts/capture-guide-screenshots.ts",
    "guide:verify-screenshots": "tsx scripts/verify-guide-screenshots.ts",
    "prebuild": "tsx scripts/build-guide-search-index.ts",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "pnpm test:int && pnpm test:e2e",
    "reindex": "tsx scripts/reindex-content-chunks.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.80.0",
    "@payloadcms/email-resend": "^3.80.0",
    "@payloadcms/live-preview-react": "^3.80.0",
    "@payloadcms/next": "^3.80.0",
    "@payloadcms/plugin-form-builder": "^3.80.0",
    "@payloadcms/plugin-multi-tenant": "^3.80.0",
    "@payloadcms/plugin-nested-docs": "^3.80.0",
    "@payloadcms/plugin-redirects": "^3.80.0",
    "@payloadcms/plugin-search": "^3.80.0",
    "@payloadcms/plugin-seo": "^3.80.0",
    "@payloadcms/richtext-lexical": "^3.80.0",
    "@payloadcms/storage-r2": "^3.80.0",
    "@payloadcms/ui": "^3.80.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "framer-motion": "^12.38.0",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "16.2.0",
    "next-intl": "^4.8.3",
    "next-mdx-remote": "^6.0.0",
    "next-sitemap": "^4.2.3",
    "openai": "^6.32.0",
    "payload": "^3.80.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "recharts": "^3.8.1",
    "redis": "^5.11.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.0",
    "jsdom": "28.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
